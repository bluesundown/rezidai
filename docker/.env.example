# Docker Environment Variables for RealtyAI
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT THIS FILE TO GIT!

# =============================================================================
# Database Configuration
# =============================================================================
# Generate a strong password: openssl rand -base64 32
DB_NAME=realtyai
DB_USER=realtyai
DB_PASSWORD=change_this_to_a_strong_random_password_minimum_32_characters

# =============================================================================
# Authentication
# =============================================================================
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_secret_key_at_least_32_characters
JWT_EXPIRATION_HOURS=24

# =============================================================================
# API Keys
# =============================================================================
QWEN_API_KEY=your_qwen_api_key_here
QWEN_ENDPOINT=https://api.qwen.ai/v1
QWEN_MODEL=qwen-vision-max

GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =============================================================================
# Stripe Payment Gateway
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# =============================================================================
# OAuth - Google
# =============================================================================
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here

# =============================================================================
# OAuth - Apple (optional)
# =============================================================================
APPLE_TEAM_ID=your_apple_team_id_here
APPLE_CLIENT_ID=your_apple_client_id_here
APPLE_CLIENT_SECRET=your_apple_client_secret_here

# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=development
APP_NAME=RealtyAI

# =============================================================================
# Mock Services (set to false in production!)
# =============================================================================
MOCK_SERVICES_ENABLED=false
MOCK_AI_RESPONSES=false
MOCK_MAPS_RESPONSES=false
MOCK_STRIPE_ENABLED=false
MOCK_OAUTH_VALIDATION=false

# =============================================================================
# CORS (comma-separated origins)
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# SendGrid Email (optional)
# =============================================================================
SENDGRID_API_KEY=your_sendgrid_api_key_here
EMAIL_FROM=noreply@realtyai.com
EMAIL_FROM_NAME=RealtyAI
